# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets and local config
.env
.env.local
.env.*.local

# Scraped + processed data (not committed; reproducible from scripts/scrape.py)
data/raw/*.json
data/processed/*.json
!data/raw/.gitkeep
!data/processed/.gitkeep

# Vector store (regenerated by scripts/ingest.py)
chroma_db/
*.sqlite3

# Caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Playwright artifacts + locally-cached browsers (pinned to D: to keep C: free)
playwright-report/
test-results/
screenshots/
.playwright-browsers/

# OS / editor / Claude Code working dir
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
.claude/

# The assignment PDF is private — do not commit
*.pdf

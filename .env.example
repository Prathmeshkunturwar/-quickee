# Copy this file to `.env` and fill in your real key.
# Never commit .env (already gitignored).

# Google Gemini API key — get yours at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Models (defaults are fine; override if you want to experiment)
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001
GEMINI_EMBED_DIM=768

# ChromaDB on-disk location
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_CATALOG_COLLECTION=quickee_catalog
CHROMA_CACHE_COLLECTION=quickee_prompt_cache

# Semantic cache similarity threshold (0.0 - 1.0). Higher = stricter match.
SEMANTIC_CACHE_THRESHOLD=0.93

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Playwright browser cache — pinned inside the project so we don't fill C:\
# (read by the Playwright CLI itself; not consumed by pydantic-settings)
PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers
